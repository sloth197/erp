{
  "ConnectionStrings": {
    "ErpDb": "Host=localhost;Port=5432;Database=erp;Username=erp;Password=change_me;Include Error Detail=true"
  },
  "Smtp": {
    "Host": "${ERP_SMTP_HOST}",
    "Port": "${ERP_SMTP_PORT}",
    "SecurityMode": "${ERP_SMTP_SECURITY_MODE}",
    "Username": "${ERP_SMTP_USERNAME}",
    "Password": "${ERP_SMTP_PASSWORD}",
    "From": "${ERP_SMTP_FROM}"
  },
  "EmailVerification": {
    "CodeLength": 8,
    "ExpiresInMinutes": 3,
    "MaxAttemptCount": 5,
    "DefaultPurpose": "signup",
    "Subject": "[ERP] Verification Code"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
