<Window x:Class="Erp.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ERP"
        Height="820"
        Width="1380"
        MinHeight="720"
        MinWidth="1120"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.WindowBackground}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="14,10"
                Background="{StaticResource Brush.TopBarBackground}"
                BorderBrush="#1F3656"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <TextBlock Text="ERP Program"
                           Style="{StaticResource Text.WindowTitle}"
                           VerticalAlignment="Center" />

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding CurrentUsername, StringFormat=User: {0}}"
                               Style="{StaticResource Text.TopBarInfo}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />

                    <Border Style="{StaticResource TopBarBadgeStyle}"
                            Background="#2F5B98"
                            BorderBrush="#4B74AE">
                        <TextBlock Text="{Binding CurrentRole}" Style="{StaticResource Text.Badge}" />
                    </Border>

                    <Border Style="{StaticResource TopBarBadgeStyle}"
                            Background="#2C7A4B"
                            BorderBrush="#479462">
                        <TextBlock Text="{Binding CurrentStatus}" Style="{StaticResource Text.Badge}" />
                    </Border>

                    <Border Style="{StaticResource TopBarBadgeStyle}">
                        <TextBlock Text="{Binding PermissionBadge}" Style="{StaticResource Text.Badge}" />
                    </Border>

                    <Button Content="Logout"
                            Style="{StaticResource TopBarActionButtonStyle}"
                            Margin="10,0,0,0"
                            Command="{Binding LogoutCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="290"
                    Background="{StaticResource Brush.SidebarBackground}"
                    BorderBrush="#1A2A45"
                    BorderThickness="0,0,1,0"
                    Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="16,14"
                            BorderBrush="#1A2A45"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="Modules" Style="{StaticResource Text.GroupTitle}" Margin="0" />
                            <TextBlock Text="Permission-based navigation"
                                       FontSize="12"
                                       Foreground="#7F93B8" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding MenuGroups}" Margin="14,12,14,14">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,14">
                                        <TextBlock Text="{Binding Title}" Style="{StaticResource Text.GroupTitle}" />

                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding Title}"
                                                            Command="{Binding Command}"
                                                            Style="{StaticResource SidebarMenuButtonStyle}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource Brush.WindowBackground}">
                <ContentControl Content="{Binding CurrentViewModel}" />
            </Border>
        </Grid>
    </Grid>
</Window>
