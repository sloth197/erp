<Window x:Class="Erp.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ERP" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- Top bar -->
        <Border DockPanel.Dock="Top" Background="#1F1F1F" Padding="12">
            <DockPanel LastChildFill="True">
                <TextBlock Text="ERP Desktop" Foreground="White" FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="Home" Command="{Binding GoHomeCommand}" Margin="8,0,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <ContentControl Content="{Binding CurrentViewModel}" />
    </DockPanel>
</Window>
