<UserControl x:Class="Erp.Desktop.Views.PlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Description}" Margin="0,10,0,0" FontSize="14" Foreground="#667085" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</UserControl>
