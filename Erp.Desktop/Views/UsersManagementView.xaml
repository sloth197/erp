<UserControl x:Class="Erp.Desktop.Views.UsersManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="사용자/권한관리" FontSize="22" FontWeight="SemiBold" />

        <TabControl Grid.Row="1" Margin="0,14,0,0">
            <TabItem Header="사용자 관리">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Margin="0,0,0,10" Padding="12" BorderThickness="1" BorderBrush="#D0D7E2" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="사용자 추가" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <WrapPanel>
                                <TextBlock Text="아이디" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBox Width="140" Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Text="비밀번호" VerticalAlignment="Center" Margin="14,0,6,0" />
                                <PasswordBox Width="140" PasswordChanged="CreatePasswordBox_OnPasswordChanged" />

                                <TextBlock Text="기본역할" VerticalAlignment="Center" Margin="14,0,6,0" />
                                <ComboBox Width="140" ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRoleForCreate}" />

                                <Button Content="사용자 생성" Margin="14,0,0,0" Command="{Binding CreateUserCommand}" />
                                <Button Content="새로고침" Margin="8,0,0,0" Command="{Binding RefreshCommand}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Text="선택 사용자 역할 부여:" VerticalAlignment="Center" />
                            <ComboBox Width="150" Margin="8,0,0,0" ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRoleForAssign}" />
                            <Button Content="역할 부여" Margin="8,0,0,0" Command="{Binding AssignRoleCommand}" />
                            <Button Content="비활성" Margin="8,0,0,0" Command="{Binding DisableSelectedUserCommand}" />
                        </WrapPanel>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Users}"
                                  SelectedItem="{Binding SelectedUser}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*" />
                                <DataGridCheckBoxColumn Header="IsActive" Binding="{Binding IsActive}" Width="90" />
                                <DataGridTextColumn Header="Failed" Binding="{Binding FailedLoginCount}" Width="70" />
                                <DataGridTextColumn Header="LockoutEndUtc" Binding="{Binding LockoutEndUtc}" Width="170" />
                                <DataGridTextColumn Header="Roles" Binding="{Binding RolesDisplay}" Width="220" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="승인 대기">
                <TabItem.Style>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CanManageApprovals}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TabItem.Style>

                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <WrapPanel Margin="0,0,0,8">
                        <TextBlock Text="검색" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBox Width="220" Text="{Binding PendingKeyword, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="목록 새로고침" Margin="8,0,0,0" Command="{Binding RefreshPendingUsersCommand}" />
                    </WrapPanel>

                    <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                        <Button Content="Approve" Command="{Binding ApprovePendingUserCommand}" />

                        <TextBlock Text="Reject Reason" VerticalAlignment="Center" Margin="14,0,6,0" />
                        <TextBox Width="180" Text="{Binding RejectReason, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="Reject" Margin="8,0,0,0" Command="{Binding RejectPendingUserCommand}" />

                        <TextBlock Text="Disable Reason" VerticalAlignment="Center" Margin="14,0,6,0" />
                        <TextBox Width="180" Text="{Binding DisableReason, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="Disable" Margin="8,0,0,0" Command="{Binding DisablePendingUserCommand}" />
                    </WrapPanel>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding PendingUsers}"
                              SelectedItem="{Binding SelectedPendingUser}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*" />
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="220" />
                            <DataGridTextColumn Header="CreatedAtUtc" Binding="{Binding CreatedAtUtc, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="180" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Margin="0,10,0,0" Foreground="#B00020" TextWrapping="Wrap" />
    </Grid>
</UserControl>
