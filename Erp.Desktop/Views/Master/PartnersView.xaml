<UserControl x:Class="Erp.Desktop.Views.PartnersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Erp.Desktop.Controls"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="CorporateFieldStyle" TargetType="{x:Type FrameworkElement}">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Editor.SelectedPartnerKind.Value}" Value="individual">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IndividualFieldStyle" TargetType="{x:Type FrameworkElement}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Editor.SelectedPartnerKind.Value}" Value="individual">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DomesticBankFieldStyle" TargetType="{x:Type FrameworkElement}">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Editor.SelectedBankScope.Value}" Value="overseas">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OverseasBankFieldStyle" TargetType="{x:Type FrameworkElement}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Editor.SelectedBankScope.Value}" Value="overseas">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PartnersGridHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#1D2939" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderBrush" Value="#D7DFEA" />
            <Setter Property="BorderThickness" Value="0,0,2,1" />
        </Style>

        <Style x:Key="PartnersGridCellStyle" TargetType="{x:Type DataGridCell}">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="BorderBrush" Value="#D7DFEA" />
            <Setter Property="BorderThickness" Value="0,0,2,1" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EEF4FF" />
                    <Setter Property="Foreground" Value="#101828" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <TextBlock DockPanel.Dock="Left"
                       Text="거래처 관리"
                       FontSize="22"
                       FontWeight="SemiBold" />

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Margin="0,0,12,0"
                           VerticalAlignment="Center"
                           Foreground="#667085"
                           Text="{Binding Partners.Count, StringFormat=등록 거래처 {0:N0}건}" />

                <Button Width="72"
                        Height="30"
                        Margin="0,0,8,0"
                        Content="수정"
                        Command="{Binding EditSelectedPartnerCommand}"
                        Visibility="{Binding ShowPartnerList, Converter={StaticResource BoolToVisibilityConverter}}" />

                <Button Width="96"
                        Height="30"
                        Content="{Binding ActionButtonText}"
                        Command="{Binding ToggleRegistrationModeCommand}"
                        IsEnabled="{Binding CanWrite}" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Padding="12"
                BorderBrush="#D0D7E2"
                BorderThickness="1"
                CornerRadius="6"
                Visibility="{Binding ShowPartnerList, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Margin="0,0,0,8"
                           Foreground="#667085"
                           Text="신규 등록 버튼을 누르면 거래처 등록 화면으로 전환됩니다." />

                <Grid Grid.Row="1">
                    <DataGrid ItemsSource="{Binding Partners}"
                              SelectedItem="{Binding SelectedPartner}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              RowHeaderWidth="0"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              BorderBrush="#D7DFEA"
                              BorderThickness="1"
                              ColumnHeaderStyle="{StaticResource PartnersGridHeaderStyle}"
                              CellStyle="{StaticResource PartnersGridCellStyle}"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.ScrollUnit="Pixel"
                              ScrollViewer.CanContentScroll="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="코드" Binding="{Binding Code}" Width="140" />
                            <DataGridTextColumn Header="거래처명" Binding="{Binding Name}" Width="2*" />
                            <DataGridTextColumn Header="거래처 종류" Binding="{Binding PartnerKind}" Width="120" />
                            <DataGridTextColumn Header="거래 구분" Binding="{Binding TransactionTypes}" Width="160" />
                            <DataGridTextColumn Header="담당자" Binding="{Binding Representative}" Width="140" />
                            <DataGridTextColumn Header="연락처" Binding="{Binding PhoneNumber}" Width="160" />
                            <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <controls:EmptyState Title="등록된 거래처가 없습니다"
                                         Description="신규 등록 버튼으로 첫 거래처를 등록해 주세요."
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                        <controls:EmptyState.Style>
                            <Style TargetType="controls:EmptyState">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Partners.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </controls:EmptyState.Style>
                    </controls:EmptyState>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Padding="12"
                BorderBrush="#D0D7E2"
                BorderThickness="1"
                CornerRadius="6"
                Visibility="{Binding ShowRegistrationForm, Converter={StaticResource BoolToVisibilityConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{Binding FormTitle}"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <controls:ValidationSummary Errors="{Binding ValidationErrors}"
                                                HasErrors="{Binding HasValidationErrors}"
                                                Margin="0,0,0,10" />
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="기본 정보"
                                   FontWeight="SemiBold"
                                   Foreground="#344054" />
                        <Border Height="1"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Background="#D0D7E2" />
                    </DockPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,0,8,8"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap">
                            <Run Foreground="#D92D20" Text="* " />
                            <Run Text="코드" />
                        </TextBlock>
                        <TextBox Grid.Row="0"
                                 Grid.Column="1"
                                 Width="220"
                                 Margin="0,0,0,8"
                                 Text="{Binding Editor.Code, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Margin="0,0,8,8"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CorporateFieldStyle}"
                                   TextWrapping="Wrap">
                            <Run Foreground="#D92D20" Text="* " />
                            <Run Text="회사명" />
                        </TextBlock>
                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Width="380"
                                 Margin="0,0,0,8"
                                 Style="{StaticResource CorporateFieldStyle}"
                                 Text="{Binding Editor.CompanyName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Margin="0,0,8,8"
                                   VerticalAlignment="Center"
                                   Text="거래처 종류" />
                        <ComboBox Grid.Row="2"
                                  Grid.Column="1"
                                  Width="180"
                                  Margin="0,0,0,8"
                                  ItemsSource="{Binding PartnerKinds}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedItem="{Binding Editor.SelectedPartnerKind}" />

                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Margin="0,0,8,8"
                                   VerticalAlignment="Center"
                                   Text="거래 구분" />
                        <WrapPanel Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="0,0,0,8">
                            <CheckBox Margin="0,0,10,0" Content="매출" IsChecked="{Binding Editor.IsSales}" />
                            <CheckBox Margin="0,0,10,0" Content="공급" IsChecked="{Binding Editor.IsSupply}" />
                            <CheckBox Margin="0,0,10,0" Content="매수금" IsChecked="{Binding Editor.IsReceivable}" />
                            <CheckBox Margin="0,0,10,0" Content="미지급금" IsChecked="{Binding Editor.IsPayable}" />
                            <CheckBox Content="기타" IsChecked="{Binding Editor.IsEtc}" />
                        </WrapPanel>

                        <DockPanel Grid.Row="4"
                                   Grid.ColumnSpan="2"
                                   Margin="0,4,0,10">
                            <TextBlock Text="사업자 / 개인 정보"
                                       FontWeight="SemiBold"
                                       Foreground="#344054" />
                            <Border Height="1"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Background="#D0D7E2" />
                        </DockPanel>

                        <TextBlock Grid.Row="5"
                                   Grid.Column="0"
                                   Margin="0,0,8,8"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CorporateFieldStyle}"
                                   TextWrapping="Wrap">
                            <Run Foreground="#D92D20" Text="* " />
                            <Run Text="사업자등록번호" />
                        </TextBlock>
                        <TextBox Grid.Row="5"
                                 Grid.Column="1"
                                 Width="260"
                                 Margin="0,0,0,8"
                                 Style="{StaticResource CorporateFieldStyle}"
                                 Text="{Binding Editor.BusinessRegistrationNumber, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="6"
                                   Grid.Column="0"
                                   Margin="0,0,8,8"
                                   VerticalAlignment="Center"
                                   Text="개인 성명"
                                   Style="{StaticResource IndividualFieldStyle}" />
                        <TextBox Grid.Row="6"
                                 Grid.Column="1"
                                 Width="220"
                                 Margin="0,0,0,8"
                                 Style="{StaticResource IndividualFieldStyle}"
                                 Text="{Binding Editor.IndividualName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="7"
                                   Grid.Column="0"
                                   Margin="0,0,8,8"
                                   VerticalAlignment="Center"
                                   Text="주민번호"
                                   Style="{StaticResource IndividualFieldStyle}" />
                        <TextBox Grid.Row="7"
                                 Grid.Column="1"
                                 Width="220"
                                 Margin="0,0,0,8"
                                 Style="{StaticResource IndividualFieldStyle}"
                                 Text="{Binding Editor.ResidentNumber, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="8"
                                   Grid.Column="0"
                                   Margin="0,0,8,8"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CorporateFieldStyle}"
                                   TextWrapping="Wrap">
                            <Run Foreground="#D92D20" Text="* " />
                            <Run Text="대표자 성명" />
                        </TextBlock>
                        <TextBox Grid.Row="8"
                                 Grid.Column="1"
                                 Width="220"
                                 Margin="0,0,0,8"
                                 Style="{StaticResource CorporateFieldStyle}"
                                 Text="{Binding Editor.RepresentativeName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="9"
                                   Grid.Column="0"
                                   Margin="0,0,8,8"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CorporateFieldStyle}"
                                   TextWrapping="Wrap">
                            <Run Foreground="#D92D20" Text="* " />
                            <Run Text="업태" />
                        </TextBlock>
                        <TextBox Grid.Row="9"
                                 Grid.Column="1"
                                 Width="220"
                                 Margin="0,0,0,8"
                                 Style="{StaticResource CorporateFieldStyle}"
                                 Text="{Binding Editor.BusinessType, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="10"
                                   Grid.Column="0"
                                   Margin="0,0,8,8"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CorporateFieldStyle}"
                                   TextWrapping="Wrap">
                            <Run Foreground="#D92D20" Text="* " />
                            <Run Text="업종" />
                        </TextBlock>
                        <TextBox Grid.Row="10"
                                 Grid.Column="1"
                                 Width="220"
                                 Margin="0,0,0,8"
                                 Style="{StaticResource CorporateFieldStyle}"
                                 Text="{Binding Editor.BusinessCategory, UpdateSourceTrigger=PropertyChanged}" />

                        <DockPanel Grid.Row="11"
                                   Grid.ColumnSpan="2"
                                   Margin="0,4,0,10">
                            <TextBlock Text="주소 / 연락처 정보"
                                       FontWeight="SemiBold"
                                       Foreground="#344054" />
                            <Border Height="1"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Background="#D0D7E2" />
                        </DockPanel>

                        <TextBlock Grid.Row="12"
                                   Grid.Column="0"
                                   Margin="0,0,8,8"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap">
                            <Run Foreground="#D92D20" Text="* " />
                            <Run Text="국가" />
                        </TextBlock>
                        <ComboBox Grid.Row="12"
                                  Grid.Column="1"
                                  Width="280"
                                  Margin="0,0,0,8"
                                  ItemsSource="{Binding Countries}"
                                  DisplayMemberPath="DisplayName"
                                  IsTextSearchEnabled="True"
                                  MaxDropDownHeight="360"
                                  SelectedItem="{Binding Editor.SelectedCountry}" />

                        <TextBlock Grid.Row="13"
                                   Grid.Column="0"
                                   Margin="0,0,8,8"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap">
                            <Run Foreground="#D92D20" Text="* " />
                            <Run Text="우편번호" />
                        </TextBlock>
                        <StackPanel Grid.Row="13"
                                    Grid.Column="1"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,8">
                            <TextBox Width="180"
                                     Margin="0,0,8,0"
                                     Text="{Binding Editor.PostalCode, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Width="70"
                                    Content="검색"
                                    Command="{Binding SearchPostalCodeCommand}"
                                    IsEnabled="{Binding IsAddressSearchEnabled}"
                                    Visibility="{Binding IsAddressSearchEnabled, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>

                        <TextBlock Grid.Row="14"
                                   Grid.Column="0"
                                   Margin="0,0,8,8"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap">
                            <Run Foreground="#D92D20" Text="* " />
                            <Run Text="주소" />
                        </TextBlock>
                        <StackPanel Grid.Row="14"
                                    Grid.Column="1"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,8">
                            <TextBox Width="402"
                                     Margin="0,0,8,0"
                                     Text="{Binding Editor.Address, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Width="70"
                                    Content="검색"
                                    Command="{Binding SearchAddressCommand}"
                                    IsEnabled="{Binding IsAddressSearchEnabled}"
                                    Visibility="{Binding IsAddressSearchEnabled, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>

                        <TextBlock Grid.Row="15"
                                   Grid.Column="0"
                                   Margin="0,0,8,8"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap">
                            <Run Foreground="#D92D20" Text="* " />
                            <Run Text="상세주소" />
                        </TextBlock>
                        <TextBox Grid.Row="15"
                                 Grid.Column="1"
                                 Width="480"
                                 Margin="0,0,0,8"
                                 Text="{Binding Editor.DetailAddress, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="16"
                                   Grid.Column="0"
                                   Margin="0,0,8,8"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap">
                            <Run Foreground="#D92D20" Text="* " />
                            <Run Text="전화번호" />
                        </TextBlock>
                        <TextBox Grid.Row="16"
                                 Grid.Column="1"
                                 Width="240"
                                 Margin="0,0,0,8"
                                 Text="{Binding Editor.PhoneNumber, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="17"
                                   Grid.Column="0"
                                   Margin="0,0,8,8"
                                   VerticalAlignment="Center"
                                   Text="핸드폰번호" />
                        <TextBox Grid.Row="17"
                                 Grid.Column="1"
                                 Width="240"
                                 Margin="0,0,0,8"
                                 Text="{Binding Editor.MobileNumber, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="18"
                                   Grid.Column="0"
                                   Margin="0,0,8,8"
                                   VerticalAlignment="Center"
                                   Text="팩스번호" />
                        <TextBox Grid.Row="18"
                                 Grid.Column="1"
                                 Width="240"
                                 Margin="0,0,0,8"
                                 Text="{Binding Editor.FaxNumber, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="19"
                                   Grid.Column="0"
                                   Margin="0,0,8,8"
                                   VerticalAlignment="Center"
                                   Text="이메일" />
                        <TextBox Grid.Row="19"
                                 Grid.Column="1"
                                 Width="320"
                                 Margin="0,0,0,8"
                                 Text="{Binding Editor.Email, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <DockPanel Margin="0,8,0,10">
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="#344054"
                                   TextWrapping="Wrap">
                            <Run Foreground="#D92D20" Text="* " />
                            <Run Text="계좌 정보" />
                        </TextBlock>
                        <Border Height="1"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Background="#D0D7E2" />
                    </DockPanel>

                    <Grid Margin="0,8,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap">
                            <Run Foreground="#D92D20" Text="* " />
                            <Run Text="은행 구분" />
                        </TextBlock>
                        <ComboBox Grid.Row="0"
                                  Grid.Column="1"
                                  Width="120"
                                  Margin="0,0,0,8"
                                  ItemsSource="{Binding BankScopes}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedItem="{Binding Editor.SelectedBankScope}" />

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Margin="0,0,8,8"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap">
                            <Run Foreground="#D92D20" Text="* " />
                            <Run Text="은행" />
                        </TextBlock>
                        <ComboBox Grid.Row="1"
                                  Grid.Column="1"
                                  Width="280"
                                  Margin="0,0,0,8"
                                  ItemsSource="{Binding DomesticBanks}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedItem="{Binding Editor.SelectedDomesticBank}"
                                  Style="{StaticResource DomesticBankFieldStyle}" />
                        <ComboBox Grid.Row="1"
                                  Grid.Column="1"
                                  Width="280"
                                  Margin="0,0,0,8"
                                  ItemsSource="{Binding OverseasBanks}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedItem="{Binding Editor.SelectedOverseasBank}"
                                  Style="{StaticResource OverseasBankFieldStyle}" />

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap">
                            <Run Foreground="#D92D20" Text="* " />
                            <Run Text="계좌번호" />
                        </TextBlock>
                        <TextBox Grid.Row="2"
                                 Grid.Column="1"
                                 Width="260"
                                 Text="{Binding Editor.AccountNumber, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Width="72"
                                Margin="0,0,8,0"
                                Content="취소"
                                Command="{Binding CancelRegistrationCommand}" />
                        <Button Width="72"
                                Content="{Binding SubmitButtonText}"
                                Command="{Binding RegisterPartnerCommand}"
                                IsEnabled="{Binding CanWrite}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <controls:MessageBar Grid.Row="2"
                             Margin="0,10,0,0"
                             Message="{Binding UserMessage.Text}"
                             Kind="{Binding UserMessage.Kind}"
                             IsOpen="{Binding HasUserMessage}" />
    </Grid>
</UserControl>
