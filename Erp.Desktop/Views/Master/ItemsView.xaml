<UserControl x:Class="Erp.Desktop.Views.ItemsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Erp.Desktop.Controls"
             mc:Ignorable="d"
             PreviewKeyDown="ItemsView_OnPreviewKeyDown">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel>
            <TextBlock DockPanel.Dock="Left" Text="품목 관리" FontSize="22" FontWeight="SemiBold" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Margin="0,0,14,0" Foreground="#667085" Text="{Binding CanRead, StringFormat=조회 권한: {0}}" />
                <TextBlock Foreground="#667085" Text="{Binding CanWrite, StringFormat=수정 권한: {0}}" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                Margin="0,12,0,12"
                Padding="12"
                BorderBrush="#D0D7E2"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.3*" />
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="검색어" Margin="0,0,0,4" />
                    <TextBox x:Name="KeywordSearchTextBox"
                             Text="{Binding SearchCriteria.Keyword, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="카테고리" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SearchCriteria.SelectedCategory}"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Text="활성 상태" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding ActiveFilters}"
                              SelectedItem="{Binding SearchCriteria.Active}"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,12,0">
                    <TextBlock Text="추적 방식" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding TrackingFilters}"
                              SelectedItem="{Binding SearchCriteria.SelectedTrackingType}"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>

                <Button Grid.Column="4"
                        Content="조회"
                        Width="84"
                        Height="30"
                        Margin="0,20,8,0"
                        VerticalAlignment="Top"
                        Command="{Binding SearchCommand}" />

                <Button Grid.Column="5"
                        Content="새로고침"
                        Width="84"
                        Height="30"
                        Margin="0,20,8,0"
                        VerticalAlignment="Top"
                        Command="{Binding LoadCommand}" />

                <Button Grid.Column="6"
                        Content="CSV 내보내기"
                        Width="100"
                        Height="30"
                        Margin="0,20,8,0"
                        VerticalAlignment="Top"
                        Command="{Binding ExportCsvCommand}"
                        IsEnabled="{Binding CanExport}" />

                <Button Grid.Column="7"
                        Content="신규"
                        Width="80"
                        Height="30"
                        Margin="0,20,0,0"
                        VerticalAlignment="Top"
                        Command="{Binding AddItemCommand}"
                        IsEnabled="{Binding CanWrite}" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               Foreground="#667085"
                               Text="{Binding TotalCount, StringFormat=총 {0:N0}건}" />

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="페이지 크기" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox Width="70"
                                  ItemsSource="{Binding PageSizes}"
                                  SelectedItem="{Binding PageSize}" />
                        <Button Content="이전"
                                Width="56"
                                Margin="8,0,0,0"
                                Command="{Binding PreviousPageCommand}" />
                        <TextBlock Margin="8,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding Page, StringFormat=페이지 {0}}" />
                        <TextBlock Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding TotalPages, StringFormat=/ {0}}" />
                        <Button Content="다음"
                                Width="56"
                                Command="{Binding NextPageCommand}" />
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1">
                    <DataGrid x:Name="ItemsGrid"
                              ItemsSource="{Binding Items}"
                              SelectedItem="{Binding SelectedItem}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              MouseDoubleClick="ItemsGrid_OnMouseDoubleClick"
                              Sorting="ItemsGrid_OnSorting"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.ScrollUnit="Pixel"
                              ScrollViewer.CanContentScroll="True"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              CanUserReorderColumns="True"
                              FrozenColumnCount="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding ItemCode}" SortMemberPath="itemCode" Width="140" />
                            <DataGridTextColumn Header="품목명" Binding="{Binding Name}" SortMemberPath="name" Width="2*" />
                            <DataGridTextColumn Header="카테고리" Binding="{Binding CategoryDisplay}" SortMemberPath="category" Width="2*" />
                            <DataGridTextColumn Header="추적방식" Binding="{Binding TrackingTypeDisplay}" SortMemberPath="trackingType" Width="110" />
                            <DataGridCheckBoxColumn Header="활성" Binding="{Binding IsActive}" SortMemberPath="isActive" Width="90" />
                            <DataGridTextColumn Header="단가" Binding="{Binding Price, StringFormat={}{0:N2}}" Width="120" CanUserSort="False" />
                            <DataGridTextColumn Header="수정일시" Binding="{Binding UpdatedAtUtc, StringFormat=yyyy-MM-dd HH:mm:ss}" SortMemberPath="updatedAtUtc" Width="170" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <controls:EmptyState Title="품목이 없습니다"
                                         Description="현재 검색 조건과 일치하는 품목이 없습니다."
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                        <controls:EmptyState.Style>
                            <Style TargetType="controls:EmptyState">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsBusy}" Value="False" />
                                            <Condition Binding="{Binding Items.Count}" Value="0" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </controls:EmptyState.Style>
                    </controls:EmptyState>
                </Grid>
            </Grid>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          Background="#E5E7EB" />

            <Border Grid.Column="2"
                    Padding="12"
                    BorderBrush="#D0D7E2"
                    BorderThickness="1"
                    CornerRadius="6">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock DockPanel.Dock="Left" Text="{Binding DetailHeader}" FontWeight="SemiBold" />
                            <TextBlock DockPanel.Dock="Right"
                                       Foreground="#B54708"
                                       Text="읽기 전용 모드">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanWrite}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DockPanel>

                        <controls:ValidationSummary Errors="{Binding ValidationErrors}"
                                                    HasErrors="{Binding HasValidationErrors}"
                                                    Margin="0,0,0,10" />

                        <Grid Margin="0,0,0,12"
                              IsEnabled="{Binding CanWrite}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="Item Code" />
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Margin="0,0,0,8"
                                     Text="{Binding Editor.ItemCode, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="품목명" />
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Margin="0,0,0,8"
                                     Text="{Binding Editor.Name, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="바코드" />
                            <TextBox Grid.Row="2" Grid.Column="1"
                                     Margin="0,0,0,8"
                                     Text="{Binding Editor.Barcode, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="카테고리" />
                            <ComboBox Grid.Row="3" Grid.Column="1"
                                      Margin="0,0,0,8"
                                      ItemsSource="{Binding EditableCategories}"
                                      SelectedItem="{Binding Editor.SelectedCategory}"
                                      DisplayMemberPath="DisplayName" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="추적 방식" />
                            <ComboBox Grid.Row="4" Grid.Column="1"
                                      Margin="0,0,0,8"
                                      ItemsSource="{Binding TrackingTypeEditOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding Editor.SelectedTrackingType}" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Text="단위(UOM)" />
                            <ComboBox Grid.Row="5" Grid.Column="1"
                                      ItemsSource="{Binding UnitOfMeasures}"
                                      SelectedItem="{Binding Editor.SelectedUnitOfMeasure}"
                                      DisplayMemberPath="DisplayName" />
                        </Grid>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Content="저장"
                                    Width="72"
                                    Margin="0,0,8,0"
                                    Command="{Binding SaveItemCommand}"
                                    IsEnabled="{Binding CanWrite}" />
                            <Button Content="취소"
                                    Width="72"
                                    Margin="0,0,8,0"
                                    Command="{Binding CancelEditCommand}"
                                    IsEnabled="{Binding CanWrite}" />
                            <Button Content="{Binding ActiveToggleButtonText}"
                                    Width="96"
                                    Command="{Binding ToggleActiveCommand}"
                                    IsEnabled="{Binding CanWrite}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <controls:MessageBar Grid.Row="3"
                             Margin="0,10,0,0"
                             Message="{Binding UserMessage.Text}"
                             Kind="{Binding UserMessage.Kind}"
                             IsOpen="{Binding HasUserMessage}" />

        <controls:BusyOverlay Grid.RowSpan="4"
                              IsBusy="{Binding IsBusy}"
                              Message="{Binding BusyMessage}" />
    </Grid>
</UserControl>
