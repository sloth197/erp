<UserControl x:Class="Erp.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <StackPanel Width="480">
            <TextBlock Text="환경설정" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="Admin 전용 설정 영역(MVP)" Margin="0,6,0,12" Foreground="#667085" />

            <CheckBox Content="상세 오류 메시지 사용" IsChecked="{Binding EnableDetailedErrors}" />

            <Button Content="저장" Width="120" Height="34" Margin="0,14,0,0" Command="{Binding SaveCommand}" />

            <TextBlock Text="{Binding StatusMessage}" Margin="0,10,0,0" Foreground="#B00020" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</UserControl>
