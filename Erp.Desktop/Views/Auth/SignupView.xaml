<UserControl x:Class="Erp.Desktop.Views.SignupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Erp.Desktop.Controls">
    <Grid Background="#F5F7FA">
        <Grid>
            <Border Width="500"
                    Padding="24"
                    Background="White"
                    BorderBrush="#D7DCE3"
                    BorderThickness="1"
                    CornerRadius="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRegistrationSucceeded}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <StackPanel>
                    <TextBlock Text="회원가입" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="이메일 인증을 완료한 뒤 회원가입할 수 있습니다."
                               Margin="0,6,0,18"
                               Foreground="#667085"
                               TextWrapping="Wrap" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,6,8,0" Text="Username" />
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,14,8,0" Text="Email" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Margin="0,8,0,0"
                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,14,8,0" Text="Password" />
                        <PasswordBox Grid.Row="2" Grid.Column="1"
                                     Margin="0,8,0,0"
                                     x:Name="PasswordBox"
                                     PasswordChanged="PasswordBox_OnPasswordChanged" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,14,8,0" Text="인증번호" />
                        <TextBox Grid.Row="3" Grid.Column="1"
                                 Margin="0,8,0,0"
                                 Text="{Binding VerificationCode, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <WrapPanel Margin="0,12,0,0">
                        <Button Content="전송 요청"
                                Width="120"
                                Height="32"
                                Command="{Binding SendVerificationCodeCommand}" />
                        <Button Content="확인"
                                Width="110"
                                Height="32"
                                Margin="8,0,0,0"
                                Command="{Binding VerifyCodeCommand}" />
                    </WrapPanel>

                    <TextBlock Margin="0,8,0,0"
                               Foreground="#667085"
                               Text="인증번호 입력 제한 시간:"
                               Visibility="{Binding IsCodeSent, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock x:Name="tbTime"
                               Foreground="#667085"
                               Visibility="{Binding IsCodeSent, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#067647"
                               FontWeight="SemiBold"
                               Text="이메일 인증 완료"
                               Visibility="{Binding IsEmailVerified, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <controls:ValidationSummary Margin="0,14,0,0"
                                                Errors="{Binding ValidationErrors}"
                                                HasErrors="{Binding HasValidationErrors}" />

                    <controls:MessageBar Margin="0,10,0,0"
                                         Message="{Binding UserMessage.Text}"
                                         Kind="{Binding UserMessage.Kind}"
                                         IsOpen="{Binding HasUserMessage}" />

                    <Button Content="회원가입 완료"
                            Command="{Binding RegisterCommand}"
                            Margin="0,18,0,0"
                            Height="38" />

                    <Button Content="로그인 화면으로 돌아가기"
                            Command="{Binding BackToLoginCommand}"
                            Margin="0,10,0,0"
                            Height="32" />
                </StackPanel>
            </Border>

            <Border Width="500"
                    Padding="24"
                    Background="White"
                    BorderBrush="#D7DCE3"
                    BorderThickness="1"
                    CornerRadius="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRegistrationSucceeded}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <StackPanel>
                    <TextBlock Text="회원가입 완료" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="이메일 인증과 계정 생성이 완료되었습니다."
                               Margin="0,6,0,16"
                               Foreground="#667085"
                               TextWrapping="Wrap" />

                    <Border Padding="14"
                            BorderThickness="1"
                            BorderBrush="#98D8AC"
                            Background="#E7F6EC"
                            CornerRadius="8">
                        <StackPanel>
                            <DockPanel>
                                <controls:StatusBadge DockPanel.Dock="Left" Status="Active" Text="Active" />
                                <TextBlock Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="#067647"
                                           Text="로그인 가능한 상태" />
                            </DockPanel>
                            <TextBlock Margin="0,10,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="#065F46"
                                       Text="이제 로그인 화면으로 이동해 방금 만든 계정으로 로그인할 수 있습니다." />
                        </StackPanel>
                    </Border>

                    <controls:MessageBar Margin="0,12,0,0"
                                         Message="{Binding UserMessage.Text}"
                                         Kind="{Binding UserMessage.Kind}"
                                         IsOpen="{Binding HasUserMessage}" />

                    <Button Content="로그인 화면으로 이동"
                            Command="{Binding BackToLoginCommand}"
                            Margin="0,16,0,0"
                            Height="36" />
                </StackPanel>
            </Border>
        </Grid>

        <controls:BusyOverlay IsBusy="{Binding IsBusy}" Message="{Binding BusyMessage}" />
    </Grid>
</UserControl>
