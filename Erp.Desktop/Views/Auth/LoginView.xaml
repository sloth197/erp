<UserControl x:Class="Erp.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Erp.Desktop.Controls">
    <Grid Background="#F5F7FA">
        <Border Width="420"
                Padding="28"
                Background="White"
                BorderBrush="#D7DCE3"
                BorderThickness="1"
                CornerRadius="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="ERP Login" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="운영 계정으로 로그인하세요."
                           Margin="0,6,0,16"
                           Foreground="#667085" />

                <Border Margin="0,0,0,16"
                        Padding="10"
                        Background="#FFF7ED"
                        BorderBrush="#FDBA74"
                        BorderThickness="1"
                        CornerRadius="6">
                    <StackPanel Orientation="Horizontal">
                        <controls:StatusBadge Status="Active" Text="Email Verified" Margin="0,0,8,0" />
                        <TextBlock VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="#B54708"
                                   Text="회원가입 시 이메일 인증을 완료해야 로그인할 수 있습니다." />
                    </StackPanel>
                </Border>

                <TextBlock Text="ID" Margin="0,0,0,4" />
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="PW" Margin="0,12,0,4" />
                <Grid>
                    <PasswordBox x:Name="PasswordBox"
                                 MinHeight="34"
                                 Padding="8,6,38,6"
                                 PasswordChanged="PasswordBox_OnPasswordChanged" />
                    <TextBox x:Name="PasswordTextBox"
                             MinHeight="34"
                             Padding="8,6,38,6"
                             VerticalContentAlignment="Center"
                             Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                             Visibility="Collapsed" />
                    <Button x:Name="TogglePasswordButton"
                            Width="30"
                            Height="30"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,2,0"
                            Click="TogglePasswordButton_OnClick"
                            ToolTip="비밀번호 보기/숨김"
                            FontSize="14"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Padding="0" />
                </Grid>

                <TextBlock Text="{Binding ErrorMessage}"
                           Margin="0,12,0,0"
                           Foreground="#B00020"
                           TextWrapping="Wrap" />

                <TextBlock Text="로그인 중..."
                           Margin="0,8,0,0"
                           Foreground="#667085"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />

                <Button Content="로그인"
                        Command="{Binding LoginCommand}"
                        Margin="0,16,0,0"
                        Height="38" />

                <Border Margin="0,12,0,0"
                        Padding="12"
                        BorderBrush="#93C5FD"
                        BorderThickness="1"
                        Background="#EFF6FF"
                        CornerRadius="6">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left"
                                   VerticalAlignment="Center"
                                   Foreground="#1E40AF"
                                   Text="계정이 없나요?" />
                        <Button DockPanel.Dock="Right"
                                Content="회원가입"
                                Command="{Binding SignUpCommand}"
                                Padding="12,4"
                                Background="#DBEAFE"
                                BorderBrush="#93C5FD" />
                    </DockPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

