<UserControl x:Class="Erp.Desktop.Views.MyInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="내 정보" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="#667085"
                       Text="계정 정보와 비밀번호 변경 메뉴를 확인합니다." />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,16,0,0"
                Padding="18,8"
                Background="White"
                BorderBrush="#D0D7E2"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <Border Padding="0,10" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="이름" Foreground="#344054" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="#101828" />
                    </Grid>
                </Border>

                <Border Padding="0,10" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="회사" Foreground="#344054" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="{Binding Company}" Foreground="#101828" />
                    </Grid>
                </Border>

                <Border Padding="0,10" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="전화번호" Foreground="#344054" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="{Binding PhoneNumber}" Foreground="#101828" />
                    </Grid>
                </Border>

                <Border Padding="0,10" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="이메일" Foreground="#344054" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="{Binding Email}" Foreground="#101828" />
                    </Grid>
                </Border>

                <Border Padding="0,10" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="직급" Foreground="#344054" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="{Binding Position}" Foreground="#101828" />
                    </Grid>
                </Border>

                <Border Padding="0,10,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="비밀번호 수정" Foreground="#344054" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="보안을 위해 표시되지 않습니다." Foreground="#667085" />
                        <Button Grid.Column="2"
                                Width="120"
                                Height="32"
                                Margin="12,0,0,0"
                                Content="비밀번호 변경"
                                Command="{Binding OpenChangePasswordCommand}" />
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="2"
                   Margin="0,10,0,0"
                   Foreground="#667085"
                   Text="{Binding Note}" />
    </Grid>
</UserControl>
