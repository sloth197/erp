<UserControl x:Class="Erp.Desktop.Views.ItemsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel>
            <TextBlock DockPanel.Dock="Left" Text="Items" FontSize="22" FontWeight="SemiBold" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Margin="0,0,14,0" Foreground="#667085" Text="{Binding CanRead, StringFormat=Read: {0}}" />
                <TextBlock Foreground="#667085" Text="{Binding CanWrite, StringFormat=Write: {0}}" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                Margin="0,12,0,12"
                Padding="12"
                BorderBrush="#D0D7E2"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Keyword" Margin="0,0,0,4" />
                    <TextBox Text="{Binding SearchCriteria.Keyword, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="Category" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SearchCriteria.SelectedCategory}"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Text="Active" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding ActiveFilters}"
                              SelectedItem="{Binding SearchCriteria.Active}"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>

                <Button Grid.Column="3"
                        Content="Search"
                        Width="90"
                        Height="30"
                        Margin="0,20,8,0"
                        VerticalAlignment="Top"
                        Command="{Binding SearchCommand}" />

                <Button Grid.Column="4"
                        Content="Reload"
                        Width="90"
                        Height="30"
                        Margin="0,20,0,0"
                        VerticalAlignment="Top"
                        Command="{Binding LoadCommand}" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="#667085"
                           Text="{Binding TotalCount, StringFormat=Total {0:N0} rows}" />

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Page Size" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox Width="70"
                              ItemsSource="{Binding PageSizes}"
                              SelectedItem="{Binding PageSize}" />
                    <Button Content="Prev"
                            Width="56"
                            Margin="8,0,0,0"
                            Command="{Binding PreviousPageCommand}" />
                    <TextBlock Margin="8,0"
                               VerticalAlignment="Center"
                               Text="{Binding Page, StringFormat=Page {0}}" />
                    <TextBlock Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Text="{Binding TotalPages, StringFormat=/ {0}}" />
                    <Button Content="Next"
                            Width="56"
                            Command="{Binding NextPageCommand}" />
                </StackPanel>
            </DockPanel>

            <DataGrid Grid.Row="1"
                      x:Name="ItemsGrid"
                      ItemsSource="{Binding Items}"
                      SelectedItem="{Binding SelectedItem}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      MouseDoubleClick="ItemsGrid_OnMouseDoubleClick"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      ScrollViewer.CanContentScroll="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Code" Binding="{Binding ItemCode}" Width="140" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
                    <DataGridTextColumn Header="Category" Binding="{Binding CategoryDisplay}" Width="2*" />
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="90" />
                    <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat={}{0:N2}}" Width="120" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Padding="12"
                BorderBrush="#D0D7E2"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Text="Item Detail" FontWeight="SemiBold" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Add"
                                Width="72"
                                Margin="0,0,8,0"
                                Command="{Binding AddItemCommand}"
                                IsEnabled="{Binding CanWrite}" />
                        <Button Content="Save"
                                Width="72"
                                Margin="0,0,8,0"
                                Command="{Binding SaveItemCommand}"
                                IsEnabled="{Binding CanWrite}" />
                        <Button Content="{Binding ActiveToggleButtonText}"
                                Width="96"
                                Command="{Binding ToggleActiveCommand}"
                                IsEnabled="{Binding CanWrite}" />
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Selected Code" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectedItem.ItemCode}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Name" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectedItem.Name}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Category" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectedItem.CategoryDisplay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Tracking / Unit" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectedItem.TrackingTypeDisplay}" />
                        <TextBlock Text="{Binding SelectedItem.UnitOfMeasureCode}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.RowSpan="4"
                Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                IsHitTestVisible="{Binding IsBusy}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="220" Height="10" />
                <TextBlock Text="Loading data..." Margin="0,10,0,0" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3"
                   Margin="0,120,0,0"
                   Foreground="#B00020"
                   Text="{Binding StatusMessage}"
                   TextWrapping="Wrap" />
    </Grid>
</UserControl>
