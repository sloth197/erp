<UserControl x:Class="Erp.Desktop.Views.ChangePasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <StackPanel Width="420">
            <TextBlock Text="비밀번호 변경" FontSize="22" FontWeight="SemiBold" />

            <TextBlock Text="현재 비밀번호" Margin="0,16,0,4" />
            <PasswordBox PasswordChanged="CurrentPasswordBox_OnPasswordChanged" />

            <TextBlock Text="새 비밀번호" Margin="0,12,0,4" />
            <PasswordBox PasswordChanged="NewPasswordBox_OnPasswordChanged" />

            <TextBlock Text="새 비밀번호 확인" Margin="0,12,0,4" />
            <PasswordBox PasswordChanged="ConfirmPasswordBox_OnPasswordChanged" />

            <Button Content="비밀번호 변경"
                    Margin="0,16,0,0"
                    Height="34"
                    Command="{Binding ChangePasswordCommand}" />

            <TextBlock Text="{Binding StatusMessage}" Margin="0,10,0,0" Foreground="#B00020" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</UserControl>
