<UserControl x:Class="Erp.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F5F7FA">
        <Border Width="360"
                Padding="24"
                Background="White"
                BorderBrush="#D7DCE3"
                BorderThickness="1"
                CornerRadius="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="ERP Login" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="운영 계정으로 로그인하세요." Margin="0,6,0,20" Foreground="#667085" />

                <TextBlock Text="ID" Margin="0,0,0,4" />
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="PW" Margin="0,12,0,4" />
                <Grid>
                    <PasswordBox x:Name="PasswordBox"
                                 Padding="0,0,34,0"
                                 PasswordChanged="PasswordBox_OnPasswordChanged" />
                    <TextBox x:Name="PasswordTextBox"
                             Padding="0,0,34,0"
                             Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                             Visibility="Collapsed" />
                    <Button x:Name="TogglePasswordButton"
                            Width="28"
                            Height="24"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"
                            Click="TogglePasswordButton_OnClick"
                            ToolTip="비밀번호 보기/숨김"
                            FontSize="13"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Padding="0" />
                </Grid>

                <TextBlock Text="{Binding ErrorMessage}" Margin="0,12,0,0" Foreground="#B00020" TextWrapping="Wrap" />

                <TextBlock Text="로그인 중..." Margin="0,8,0,0" Foreground="#667085">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="로그인"
                            Command="{Binding LoginCommand}"
                            Height="36" />

                    <Button Grid.Column="2"
                            Content="회원가입"
                            Command="{Binding SignUpCommand}"
                            Height="36" />
                </Grid>

                <TextBlock Text="관리자/스태프 계정은 보안 시드 설정에서 구성하세요."
                           Margin="0,14,0,0"
                           Foreground="#667085"
                           FontSize="12"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
