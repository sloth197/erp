<UserControl x:Class="Erp.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F5F7FA">
        <Border Width="360"
                Padding="24"
                Background="White"
                BorderBrush="#D7DCE3"
                BorderThickness="1"
                CornerRadius="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="ERP 로그인" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="운영 계정으로 로그인하세요." Margin="0,6,0,20" Foreground="#667085" />

                <TextBlock Text="아이디" Margin="0,0,0,4" />
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="비밀번호" Margin="0,12,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <PasswordBox x:Name="PasswordBox"
                                     PasswordChanged="PasswordBox_OnPasswordChanged" />
                        <TextBox x:Name="PasswordTextBox"
                                 Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="Collapsed" />
                    </Grid>

                    <Button x:Name="TogglePasswordButton"
                            Grid.Column="1"
                            Width="58"
                            Margin="8,0,0,0"
                            Content="보기"
                            Click="TogglePasswordButton_OnClick" />
                </Grid>

                <TextBlock Text="{Binding ErrorMessage}" Margin="0,12,0,0" Foreground="#B00020" TextWrapping="Wrap" />

                <TextBlock Text="로그인 중..." Margin="0,8,0,0" Foreground="#667085">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Button Content="로그인"
                        Command="{Binding LoginCommand}"
                        Margin="0,16,0,0"
                        Height="36" />

                <TextBlock Text="관리자/스태프 계정은 보안 시드 설정에서 구성하세요."
                           Margin="0,14,0,0"
                           Foreground="#667085"
                           FontSize="12"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
