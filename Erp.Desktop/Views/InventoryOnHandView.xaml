<UserControl x:Class="Erp.Desktop.Views.InventoryOnHandView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="재고조회(현재고)" FontSize="22" FontWeight="SemiBold" />

        <Border Grid.Row="1"
                Margin="0,12,0,10"
                Padding="12"
                BorderBrush="#D0D7E2"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.8*" />
                    <ColumnDefinition Width="1.6*" />
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="창고(필수)" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Warehouses}"
                              SelectedItem="{Binding SelectedWarehouse}"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="키워드" Margin="0,0,0,4" />
                    <TextBox Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="카테고리" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,18,10,0" VerticalAlignment="Top">
                    <CheckBox Content="로케이션별 보기"
                              IsChecked="{Binding IncludeLocations}" />
                </StackPanel>

                <Button Grid.Column="4"
                        Content="검색"
                        Width="84"
                        Height="30"
                        Margin="0,18,8,0"
                        VerticalAlignment="Top"
                        Command="{Binding SearchCommand}" />

                <Button Grid.Column="5"
                        Content="새로고침"
                        Width="84"
                        Height="30"
                        Margin="0,18,0,0"
                        VerticalAlignment="Top"
                        Command="{Binding LoadCommand}" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="#667085"
                           Text="{Binding TotalCount, StringFormat=총 {0:N0}건}" />

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="정렬" Margin="0,0,6,0" VerticalAlignment="Center" />
                    <ComboBox Width="110"
                              ItemsSource="{Binding SortFields}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Key"
                              SelectedValue="{Binding SelectedSort}" />
                    <ComboBox Width="96"
                              Margin="6,0,0,0"
                              ItemsSource="{Binding SortDirections}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Key"
                              SelectedValue="{Binding SelectedSortDirection}" />

                    <TextBlock Text="페이지 크기" Margin="14,0,6,0" VerticalAlignment="Center" />
                    <ComboBox Width="70"
                              ItemsSource="{Binding PageSizes}"
                              SelectedItem="{Binding PageSize}" />

                    <Button Content="이전"
                            Width="56"
                            Margin="10,0,0,0"
                            Command="{Binding PreviousPageCommand}" />
                    <TextBlock Margin="8,0"
                               VerticalAlignment="Center"
                               Text="{Binding Page, StringFormat={}{0} / }" />
                    <TextBlock Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Text="{Binding TotalPages}" />
                    <Button Content="다음"
                            Width="56"
                            Command="{Binding NextPageCommand}" />
                </StackPanel>
            </DockPanel>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Rows}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      ScrollViewer.CanContentScroll="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ItemCode" Binding="{Binding ItemCode}" Width="150" />
                    <DataGridTextColumn Header="Name" Binding="{Binding ItemName}" Width="2*" />
                    <DataGridTextColumn Header="QtyOnHand" Binding="{Binding QtyOnHand, StringFormat={}{0:N4}}" Width="130" />
                    <DataGridTextColumn Header="Warehouse" Binding="{Binding WarehouseCode}" Width="120" />
                    <DataGridTextColumn Header="Location" Binding="{Binding LocationCode}" Width="120" />
                    <DataGridTextColumn Header="UpdatedAt" Binding="{Binding UpdatedAtUtc, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="170" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <TextBlock Grid.Row="3"
                   Margin="0,10,0,0"
                   Foreground="#B00020"
                   Text="{Binding StatusMessage}"
                   TextWrapping="Wrap" />

        <Border Grid.RowSpan="4"
                Background="#70FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Width="220" Height="10" IsIndeterminate="True" />
                <TextBlock Margin="0,10,0,0" Text="현재고 조회 중..." />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
