<UserControl x:Class="Erp.Desktop.Views.StockReceiptView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="입고 등록" FontSize="22" FontWeight="SemiBold" />

        <Border Grid.Row="1"
                Margin="0,12,0,8"
                Padding="12"
                BorderBrush="#D0D7E2"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="창고" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Warehouses}"
                              SelectedItem="{Binding SelectedWarehouse}"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="로케이션(선택)" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Locations}"
                              SelectedItem="{Binding SelectedLocation}"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="거래일자" Margin="0,0,0,4" />
                    <DatePicker SelectedDate="{Binding OccurredAt}" />
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="+ 라인"
                            Width="80"
                            Margin="0,0,8,0"
                            Command="{Binding AddLineCommand}" />
                    <Button Content="- 라인"
                            Width="80"
                            Command="{Binding RemoveLineCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,0,0,8"
                Padding="12"
                BorderBrush="#D0D7E2"
                BorderThickness="1"
                CornerRadius="6">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="품목 검색" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Width="240"
                             Text="{Binding ItemKeyword, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="검색"
                            Width="72"
                            Margin="8,0,0,0"
                            Command="{Binding SearchItemsCommand}" />
                </StackPanel>

                <TextBlock DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Foreground="#475467"
                           Text="{Binding LastTxNo, StringFormat=최근 TxNo: {0}}" />
            </DockPanel>
        </Border>

        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Lines}"
                  SelectedItem="{Binding SelectedLine}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.ScrollUnit="Pixel"
                  ScrollViewer.CanContentScroll="True">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="품목" Width="2.2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding DataContext.ItemOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedItem="{Binding SelectedItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      DisplayMemberPath="DisplayName"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Tracking" Binding="{Binding SelectedItem.TrackingType}" Width="110" IsReadOnly="True" />
                <DataGridTextColumn Header="Qty" Binding="{Binding Qty, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                <DataGridTextColumn Header="UnitCost" Binding="{Binding UnitCost, UpdateSourceTrigger=PropertyChanged}" Width="110" />
                <DataGridTextColumn Header="LotNo" Binding="{Binding LotNo, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                <DataGridTextColumn Header="SerialNo" Binding="{Binding SerialNo, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                <DataGridTemplateColumn Header="ExpiryDate" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <DatePicker SelectedDate="{Binding ExpiryDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Note" Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}" Width="1.5*" />
                <DataGridTextColumn Header="오류" Binding="{Binding ErrorMessage}" Width="2*" IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="4" Margin="0,10,0,0">
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Foreground="#B00020"
                       Text="{Binding StatusMessage}" />
            <Button DockPanel.Dock="Right"
                    Width="130"
                    Height="32"
                    Content="입고 저장"
                    IsEnabled="{Binding CanReceipt}"
                    Command="{Binding SaveCommand}" />
        </DockPanel>

        <Border Grid.RowSpan="5"
                Background="#70FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Width="220" Height="10" IsIndeterminate="True" />
                <TextBlock Margin="0,10,0,0" Text="입고 처리 중..." />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
