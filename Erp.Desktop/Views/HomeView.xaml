<UserControl x:Class="Erp.Desktop.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Subtitle}" Margin="0,8,0,0" FontSize="14" Opacity="0.8" />
            <Separator Margin="0,16,0,16"/>
            <TextBlock Text="Next: EF Core DbContext + Login/Role + Item CRUD" FontSize="12" Opacity="0.7"/>
        </StackPanel>
    </Grid>
</UserControl>
