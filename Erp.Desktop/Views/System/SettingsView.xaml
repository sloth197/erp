<UserControl x:Class="Erp.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Erp.Desktop.Controls">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="환경설정"
                   FontSize="22"
                   FontWeight="SemiBold" />

        <StackPanel Grid.Row="1"
                    Margin="0,8,0,10">
            <TextBlock Foreground="#667085"
                       Text="{Binding PermissionSummary}" />
            <TextBlock Margin="0,2,0,0"
                       Foreground="#667085"
                       Text="{Binding ApplyModeGuide}" />
            <TextBlock Margin="0,2,0,0"
                       Foreground="#1D4ED8"
                       FontWeight="SemiBold"
                       Text="{Binding UnsavedChangesSummary}" />
            <TextBlock Margin="0,2,0,0"
                       Foreground="#667085"
                       Text="{Binding LastSavedText}" />
        </StackPanel>

        <controls:ValidationSummary Grid.Row="2"
                                    Margin="0,0,0,10"
                                    Errors="{Binding ValidationErrors}"
                                    HasErrors="{Binding HasValidationErrors}" />

        <Border Grid.Row="3"
                Padding="14"
                BorderBrush="#D0D7E2"
                BorderThickness="1"
                CornerRadius="6">
            <Grid IsEnabled="{Binding CanWrite}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,0,12,12"
                           Text="상세 오류 메시지" />
                <CheckBox Grid.Row="0"
                          Grid.Column="1"
                          Margin="0,0,0,12"
                          VerticalAlignment="Center"
                          IsChecked="{Binding EnableDetailedErrors}" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,0,12,12"
                           Text="변경 이력 감사 로그" />
                <CheckBox Grid.Row="1"
                          Grid.Column="1"
                          Margin="0,0,0,12"
                          VerticalAlignment="Center"
                          IsChecked="{Binding EnableAuditTrail}" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,0,12,12"
                           Text="세션 만료 시간(분)" />
                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Margin="0,0,0,12"
                         Text="{Binding SessionTimeoutMinutesInput, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           Text="날짜 표시 형식" />
                <TextBox Grid.Row="3"
                         Grid.Column="1"
                         Text="{Binding DateDisplayFormat, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="4"
                    Margin="0,12,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="기본값 복원"
                    Width="100"
                    Height="32"
                    Margin="0,0,8,0"
                    Command="{Binding RestoreDefaultsCommand}" />
            <Button Content="취소"
                    Width="84"
                    Height="32"
                    Margin="0,0,8,0"
                    Command="{Binding CancelCommand}" />
            <Button Content="저장"
                    Width="84"
                    Height="32"
                    Command="{Binding SaveCommand}" />
        </StackPanel>

        <controls:MessageBar Grid.Row="4"
                             Margin="0,50,0,0"
                             Message="{Binding UserMessage.Text}"
                             Kind="{Binding UserMessage.Kind}"
                             IsOpen="{Binding HasUserMessage}" />

        <controls:BusyOverlay Grid.RowSpan="5"
                              IsBusy="{Binding IsBusy}"
                              Message="{Binding BusyMessage}" />
    </Grid>
</UserControl>
