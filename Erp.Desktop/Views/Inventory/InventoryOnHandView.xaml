<UserControl x:Class="Erp.Desktop.Views.InventoryOnHandView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Erp.Desktop.Controls">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Inventory On-hand" FontSize="22" FontWeight="SemiBold" />

        <Border Grid.Row="1"
                Margin="0,12,0,10"
                Padding="12"
                BorderBrush="#D0D7E2"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.8*" />
                    <ColumnDefinition Width="1.6*" />
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Warehouse (required)" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Warehouses}"
                              SelectedItem="{Binding SelectedWarehouse}"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Keyword" Margin="0,0,0,4" />
                    <TextBox Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Category" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,18,10,0" VerticalAlignment="Top">
                    <CheckBox Content="Include Locations"
                              IsChecked="{Binding IncludeLocations}" />
                </StackPanel>

                <Button Grid.Column="4"
                        Content="Search"
                        Width="84"
                        Height="30"
                        Margin="0,18,8,0"
                        VerticalAlignment="Top"
                        Command="{Binding SearchCommand}" />

                <Button Grid.Column="5"
                        Content="Reload"
                        Width="84"
                        Height="30"
                        Margin="0,18,0,0"
                        VerticalAlignment="Top"
                        Command="{Binding LoadCommand}" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="#667085"
                           Text="{Binding TotalCount, StringFormat=Total {0:N0} rows}" />

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Sort" Margin="0,0,6,0" VerticalAlignment="Center" />
                    <ComboBox Width="110"
                              ItemsSource="{Binding SortFields}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Key"
                              SelectedValue="{Binding SelectedSort}" />
                    <ComboBox Width="96"
                              Margin="6,0,0,0"
                              ItemsSource="{Binding SortDirections}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Key"
                              SelectedValue="{Binding SelectedSortDirection}" />

                    <TextBlock Text="Page size" Margin="14,0,6,0" VerticalAlignment="Center" />
                    <ComboBox Width="70"
                              ItemsSource="{Binding PageSizes}"
                              SelectedItem="{Binding PageSize}" />

                    <Button Content="Prev"
                            Width="56"
                            Margin="10,0,0,0"
                            Command="{Binding PreviousPageCommand}" />
                    <TextBlock Margin="8,0"
                               VerticalAlignment="Center"
                               Text="{Binding Page, StringFormat={}{0} / }" />
                    <TextBlock Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Text="{Binding TotalPages}" />
                    <Button Content="Next"
                            Width="56"
                            Command="{Binding NextPageCommand}" />
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1">
                <DataGrid ItemsSource="{Binding Rows}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.ScrollUnit="Pixel"
                          ScrollViewer.CanContentScroll="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ItemCode" Binding="{Binding ItemCode}" Width="150" />
                        <DataGridTextColumn Header="Name" Binding="{Binding ItemName}" Width="2*" />
                        <DataGridTextColumn Header="QtyOnHand" Binding="{Binding QtyOnHand, StringFormat={}{0:N4}}" Width="130" />
                        <DataGridTextColumn Header="Warehouse" Binding="{Binding WarehouseCode}" Width="120" />
                        <DataGridTextColumn Header="Location" Binding="{Binding LocationCode}" Width="120" />
                        <DataGridTextColumn Header="UpdatedAt" Binding="{Binding UpdatedAtUtc, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="170" />
                    </DataGrid.Columns>
                </DataGrid>

                <controls:EmptyState Title="No Inventory Rows"
                                     Description="No stock rows matched the current filter."
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                    <controls:EmptyState.Style>
                        <Style TargetType="controls:EmptyState">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsBusy}" Value="False" />
                                        <Condition Binding="{Binding Rows.Count}" Value="0" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </controls:EmptyState.Style>
                </controls:EmptyState>
            </Grid>
        </Grid>

        <controls:MessageBar Grid.Row="3"
                             Margin="0,10,0,0"
                             Message="{Binding UserMessage.Text}"
                             Kind="{Binding UserMessage.Kind}"
                             IsOpen="{Binding HasUserMessage}" />

        <controls:BusyOverlay Grid.RowSpan="4"
                              IsBusy="{Binding IsBusy}"
                              Message="{Binding BusyMessage}" />
    </Grid>
</UserControl>
