<UserControl x:Class="Erp.Desktop.Views.InventoryOnHandView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Erp.Desktop.Controls">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="재고 조회" FontSize="22" FontWeight="SemiBold" />

        <Border Grid.Row="1"
                Margin="0,12,0,10"
                Padding="12"
                BorderBrush="#D0D7E2"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.8*" />
                    <ColumnDefinition Width="1.6*" />
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="창고 (필수)" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Warehouses}"
                              SelectedItem="{Binding SelectedWarehouse}"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="검색어" Margin="0,0,0,4" />
                    <TextBox Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="카테고리" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,18,10,0" VerticalAlignment="Top">
                    <CheckBox Content="로케이션 포함"
                              IsChecked="{Binding IncludeLocations}" />
                </StackPanel>

                <Button Grid.Column="4"
                        Content="조회"
                        Width="84"
                        Height="30"
                        Margin="0,18,8,0"
                        VerticalAlignment="Top"
                        Command="{Binding SearchCommand}" />

                <Button Grid.Column="5"
                        Content="새로고침"
                        Width="84"
                        Height="30"
                        Margin="0,18,0,0"
                        VerticalAlignment="Top"
                        Command="{Binding LoadCommand}" />

                <Border Grid.Row="1"
                        Grid.ColumnSpan="6"
                        Margin="0,12,0,0"
                        Padding="10"
                        BorderBrush="#E4E7EC"
                        BorderThickness="1"
                        CornerRadius="4"
                        Background="#F8FAFC">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="관리 기능"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Margin="0,0,10,0" />

                        <Button Content="입고 등록"
                                Width="86"
                                Command="{Binding OpenStockReceiptCommand}" />
                        <Button Content="출고 등록"
                                Width="86"
                                Margin="6,0,0,0"
                                Command="{Binding OpenStockIssueCommand}" />

                        <TextBlock Text="실사수량"
                                   VerticalAlignment="Center"
                                   Margin="14,0,6,0" />
                        <TextBox Width="100"
                                 Text="{Binding CountedQtyInput, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="비고"
                                   VerticalAlignment="Center"
                                   Margin="10,0,6,0" />
                        <TextBox Width="220"
                                 Text="{Binding AdjustNote, UpdateSourceTrigger=PropertyChanged}" />

                        <Button Content="실사 조정 반영"
                                Margin="10,0,0,0"
                                Width="110"
                                Command="{Binding ApplyCountAdjustmentCommand}" />

                        <TextBlock Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#667085"
                                   Text="{Binding SelectedRowSummary}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="#667085"
                           Text="{Binding TotalCount, StringFormat=총 {0:N0}건}" />

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="정렬" Margin="0,0,6,0" VerticalAlignment="Center" />
                    <ComboBox Width="110"
                              ItemsSource="{Binding SortFields}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Key"
                              SelectedValue="{Binding SelectedSort}" />
                    <ComboBox Width="96"
                              Margin="6,0,0,0"
                              ItemsSource="{Binding SortDirections}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Key"
                              SelectedValue="{Binding SelectedSortDirection}" />

                    <TextBlock Text="페이지 크기" Margin="14,0,6,0" VerticalAlignment="Center" />
                    <ComboBox Width="70"
                              ItemsSource="{Binding PageSizes}"
                              SelectedItem="{Binding PageSize}" />

                    <Button Content="이전"
                            Width="56"
                            Margin="10,0,0,0"
                            Command="{Binding PreviousPageCommand}" />
                    <TextBlock Margin="8,0"
                               VerticalAlignment="Center"
                               Text="{Binding Page, StringFormat=페이지 {0} / }" />
                    <TextBlock Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Text="{Binding TotalPages}" />
                    <Button Content="다음"
                            Width="56"
                            Command="{Binding NextPageCommand}" />
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1">
                <DataGrid ItemsSource="{Binding Rows}"
                          SelectedItem="{Binding SelectedRow}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.ScrollUnit="Pixel"
                          ScrollViewer.CanContentScroll="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Item Code" Binding="{Binding ItemCode}" Width="150" />
                        <DataGridTextColumn Header="품목명" Binding="{Binding ItemName}" Width="2*" />
                        <DataGridTextColumn Header="재고수량" Binding="{Binding QtyOnHand, StringFormat={}{0:N4}}" Width="130" />
                        <DataGridTextColumn Header="창고" Binding="{Binding WarehouseCode}" Width="120" />
                        <DataGridTextColumn Header="로케이션" Binding="{Binding LocationCode}" Width="120" />
                        <DataGridTextColumn Header="수정일시" Binding="{Binding UpdatedAtUtc, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="170" />
                    </DataGrid.Columns>
                </DataGrid>

                <controls:EmptyState Title="재고 데이터가 없습니다"
                                     Description="현재 검색 조건과 일치하는 재고가 없습니다."
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                    <controls:EmptyState.Style>
                        <Style TargetType="controls:EmptyState">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsBusy}" Value="False" />
                                        <Condition Binding="{Binding Rows.Count}" Value="0" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </controls:EmptyState.Style>
                </controls:EmptyState>
            </Grid>
        </Grid>

        <controls:MessageBar Grid.Row="3"
                             Margin="0,10,0,0"
                             Message="{Binding UserMessage.Text}"
                             Kind="{Binding UserMessage.Kind}"
                             IsOpen="{Binding HasUserMessage}" />

        <controls:BusyOverlay Grid.RowSpan="4"
                              IsBusy="{Binding IsBusy}"
                              Message="{Binding BusyMessage}" />
    </Grid>
</UserControl>
