<UserControl x:Class="Erp.Desktop.Views.StockAdjustView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="재고조정(실사)" FontSize="22" FontWeight="SemiBold" />

        <Border Grid.Row="1"
                Margin="0,12,0,8"
                Padding="12"
                BorderBrush="#D0D7E2"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="창고" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Warehouses}"
                              SelectedItem="{Binding SelectedWarehouse}"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="로케이션(선택)" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Locations}"
                              SelectedItem="{Binding SelectedLocation}"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="실사일자" Margin="0,0,0,4" />
                    <DatePicker SelectedDate="{Binding OccurredAt}" />
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="+ 라인"
                            Width="80"
                            Margin="0,0,8,0"
                            Command="{Binding AddLineCommand}" />
                    <Button Content="- 라인"
                            Width="80"
                            Command="{Binding RemoveLineCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,0,0,8"
                Padding="12"
                BorderBrush="#D0D7E2"
                BorderThickness="1"
                CornerRadius="6">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="품목 검색" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Width="240"
                             Text="{Binding ItemKeyword, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="검색"
                            Width="72"
                            Margin="8,0,0,0"
                            Command="{Binding SearchItemsCommand}" />
                </StackPanel>

                <TextBlock DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Foreground="#475467"
                           Text="{Binding LastTxNo, StringFormat=최근 TxNo: {0}}" />
            </DockPanel>
        </Border>

        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Lines}"
                  SelectedItem="{Binding SelectedLine}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="품목" Width="2.6*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding DataContext.ItemOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedItem="{Binding SelectedItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      DisplayMemberPath="DisplayName"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Tracking" Binding="{Binding SelectedItem.TrackingType}" Width="110" IsReadOnly="True" />
                <DataGridTextColumn Header="실사수량" Binding="{Binding CountedQty, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                <DataGridTextColumn Header="Note" Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}" Width="1.8*" />
                <DataGridTextColumn Header="라인 오류" Binding="{Binding ErrorMessage}" Width="2.4*" IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="4" Margin="0,10,0,10">
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Foreground="#B00020"
                       Text="{Binding StatusMessage}" />
            <Button DockPanel.Dock="Right"
                    Width="140"
                    Height="32"
                    Content="조정 저장"
                    IsEnabled="{Binding CanAdjust}"
                    Command="{Binding SaveCommand}" />
        </DockPanel>

        <Border Grid.Row="5"
                Padding="10"
                BorderBrush="#D0D7E2"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Diff 요약" FontWeight="SemiBold" Margin="0,0,0,8" />
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding LastDiffRows}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ItemCode" Binding="{Binding ItemCode}" Width="140" />
                        <DataGridTextColumn Header="Name" Binding="{Binding ItemName}" Width="2*" />
                        <DataGridTextColumn Header="CurrentQty" Binding="{Binding CurrentQty, StringFormat={}{0:N4}}" Width="120" />
                        <DataGridTextColumn Header="CountedQty" Binding="{Binding CountedQty, StringFormat={}{0:N4}}" Width="120" />
                        <DataGridTextColumn Header="DiffQty" Binding="{Binding DiffQty, StringFormat={}{0:N4}}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.RowSpan="6"
                Background="#70FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Width="220" Height="10" IsIndeterminate="True" />
                <TextBlock Margin="0,10,0,0" Text="재고조정 처리 중..." />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
