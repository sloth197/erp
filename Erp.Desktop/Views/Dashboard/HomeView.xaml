<UserControl x:Class="Erp.Desktop.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Erp.Desktop.Controls">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="{Binding Title}" FontSize="26" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Subtitle}" Margin="0,4,0,0" Foreground="#475467" />
            </StackPanel>

            <Button DockPanel.Dock="Right"
                    Content="새로고침"
                    Width="92"
                    Height="34"
                    Margin="12,0,0,0"
                    Command="{Binding RefreshCommand}" />
        </DockPanel>

        <TextBlock Grid.Row="1"
                   Margin="0,10,0,0"
                   Foreground="#667085"
                   Text="{Binding LastUpdatedText}" />

        <ScrollViewer Grid.Row="2"
                      Margin="0,14,0,0"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <UniformGrid Columns="3" Margin="0,0,0,14">
                    <Border Margin="0,0,10,10" Padding="12" Background="White" BorderBrush="#D0D7E2" BorderThickness="1" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="품목" FontSize="12" Foreground="#667085" />
                            <TextBlock Text="{Binding TotalItems, StringFormat={}{0:N0}}" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding ActiveItems, StringFormat=활성 {0:N0}}" Foreground="#067647" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,10,10" Padding="12" Background="White" BorderBrush="#D0D7E2" BorderThickness="1" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="재고" FontSize="12" Foreground="#667085" />
                            <TextBlock Text="{Binding TotalOnHandQty, StringFormat={}{0:N2}}" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding StockTransactionsToday, StringFormat=오늘 거래 {0:N0}}" Foreground="#1D4ED8" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,0,10" Padding="12" Background="White" BorderBrush="#D0D7E2" BorderThickness="1" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="창고/로케이션" FontSize="12" Foreground="#667085" />
                            <TextBlock Text="{Binding WarehouseCount, StringFormat={}{0:N0}}" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding LocationCount, StringFormat=로케이션 {0:N0}}" Foreground="#475467" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,10,10" Padding="12" Background="White" BorderBrush="#D0D7E2" BorderThickness="1" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="사용자" FontSize="12" Foreground="#667085" />
                            <TextBlock Text="{Binding ActiveUserCount, StringFormat={}{0:N0}}" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding PendingUserCount, StringFormat=대기 {0:N0}}" Foreground="#B54708" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Margin="0,0,0,14" Padding="14" Background="White" BorderBrush="#D0D7E2" BorderThickness="1" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="빠른 이동" FontSize="14" FontWeight="SemiBold" />
                        <WrapPanel Margin="0,10,0,0">
                            <Button Content="품목 관리" Margin="0,0,8,8" Command="{Binding OpenItemsCommand}" IsEnabled="{Binding CanOpenItems}" />
                            <Button Content="재고 조회" Margin="0,0,8,8" Command="{Binding OpenInventoryOnHandCommand}" IsEnabled="{Binding CanOpenInventoryOnHand}" />
                            <Button Content="입고 등록" Margin="0,0,8,8" Command="{Binding OpenStockReceiptCommand}" IsEnabled="{Binding CanOpenStockReceipt}" />
                            <Button Content="사용자/권한" Margin="0,0,8,8" Command="{Binding OpenUsersManagementCommand}" IsEnabled="{Binding CanOpenUsers}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <controls:MessageBar Grid.Row="3"
                             Margin="0,10,0,0"
                             Message="{Binding UserMessage.Text}"
                             Kind="{Binding UserMessage.Kind}"
                             IsOpen="{Binding HasUserMessage}" />

        <controls:BusyOverlay Grid.RowSpan="4"
                              IsBusy="{Binding IsBusy}"
                              Message="{Binding BusyMessage}" />
    </Grid>
</UserControl>
