<UserControl x:Class="Erp.Desktop.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Erp.Desktop.Controls">
    <UserControl.Resources>
        <Style x:Key="DashboardCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="{StaticResource Brush.SurfacePrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderDefault}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="DashboardCardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#475467" />
        </Style>

        <Style x:Key="DashboardCardValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,7,0,3" />
            <Setter Property="Foreground" Value="#0F172A" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="{Binding Title}" FontSize="26" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Subtitle}" Margin="0,4,0,0" Foreground="#475467" />
            </StackPanel>

            <Button DockPanel.Dock="Right"
                    Content="새로고침"
                    Width="92"
                    Height="34"
                    Margin="12,0,0,0"
                    Command="{Binding RefreshCommand}" />
        </DockPanel>

        <TextBlock Grid.Row="1"
                   Margin="0,10,0,0"
                   Foreground="#667085"
                   Text="{Binding LastUpdatedText}" />

        <ScrollViewer Grid.Row="2"
                      Margin="0,14,0,0"
                      VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="1.25*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="0" Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource DashboardCardStyle}">
                        <StackPanel>
                            <TextBlock Text="품목" Style="{StaticResource DashboardCardTitleStyle}" />
                            <TextBlock Text="{Binding TotalItems, StringFormat={}{0:N0}}" Style="{StaticResource DashboardCardValueStyle}" />
                            <TextBlock Text="{Binding ActiveItems, StringFormat=활성 {0:N0}}" Foreground="{StaticResource Brush.Success}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource DashboardCardStyle}">
                        <StackPanel>
                            <TextBlock Text="창고/로케이션" Style="{StaticResource DashboardCardTitleStyle}" />
                            <TextBlock Text="{Binding WarehouseCount, StringFormat={}{0:N0}}" Style="{StaticResource DashboardCardValueStyle}" />
                            <TextBlock Text="{Binding LocationCount, StringFormat=로케이션 {0:N0}}" Foreground="#475467" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,12,0,0"
                        Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="사용자" Style="{StaticResource DashboardCardTitleStyle}" />
                        <TextBlock Text="{Binding ActiveUserCount, StringFormat={}{0:N0}}" Style="{StaticResource DashboardCardValueStyle}" />
                        <TextBlock Text="{Binding PendingUserCount, StringFormat=대기 {0:N0}}" Foreground="{StaticResource Brush.Warning}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="2"
                        Style="{StaticResource DashboardCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" LastChildFill="False">
                            <TextBlock Text="재고" Style="{StaticResource DashboardCardTitleStyle}" />
                            <TextBlock DockPanel.Dock="Right"
                                       Text="30분 단위"
                                       Foreground="#667085"
                                       FontSize="12" />
                        </DockPanel>

                        <Border Grid.Row="1"
                                Margin="0,10,0,10"
                                Background="#F8FBFF"
                                BorderBrush="#D3DCE8"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10">
                            <Grid>
                                <Canvas Width="300" Height="120" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Line X1="0" Y1="110" X2="300" Y2="110" Stroke="#D6DFEB" StrokeThickness="1" />
                                    <Line X1="0" Y1="70" X2="300" Y2="70" Stroke="#E6EDF6" StrokeThickness="1" />
                                    <Line X1="0" Y1="30" X2="300" Y2="30" Stroke="#E6EDF6" StrokeThickness="1" />
                                    <Polyline Points="{Binding StockTrendPoints}"
                                              Stroke="#1D4ED8"
                                              StrokeThickness="2.5"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" />
                                </Canvas>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="현재" FontSize="12" Foreground="#667085" />
                                <TextBlock Text="{Binding StockTrendCurrentText}" FontSize="14" FontWeight="SemiBold" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="최저" FontSize="12" Foreground="#667085" />
                                <TextBlock Text="{Binding StockTrendMinText}" FontSize="14" FontWeight="SemiBold" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="최고" FontSize="12" Foreground="#667085" />
                                <TextBlock Text="{Binding StockTrendMaxText}" FontSize="14" FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Margin="0,14,0,0"
                        Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="빠른 이동" FontSize="14" FontWeight="SemiBold" />
                        <WrapPanel Margin="0,10,0,0">
                            <Button Content="품목 관리"
                                    Margin="0,0,8,8"
                                    Command="{Binding OpenItemsCommand}"
                                    IsEnabled="{Binding CanOpenItems}" />
                            <Button Content="재고 조회"
                                    Margin="0,0,8,8"
                                    Command="{Binding OpenInventoryOnHandCommand}"
                                    IsEnabled="{Binding CanOpenInventoryOnHand}" />
                            <Button Content="입고 등록"
                                    Margin="0,0,8,8"
                                    Command="{Binding OpenStockReceiptCommand}"
                                    IsEnabled="{Binding CanOpenStockReceipt}" />
                            <Button Content="사용자/권한"
                                    Margin="0,0,8,8"
                                    Command="{Binding OpenUsersManagementCommand}"
                                    IsEnabled="{Binding CanOpenUsers}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <controls:MessageBar Grid.Row="3"
                             Margin="0,10,0,0"
                             Message="{Binding UserMessage.Text}"
                             Kind="{Binding UserMessage.Kind}"
                             IsOpen="{Binding HasUserMessage}" />

        <controls:BusyOverlay Grid.RowSpan="4"
                              IsBusy="{Binding IsBusy}"
                              Message="{Binding BusyMessage}" />
    </Grid>
</UserControl>
