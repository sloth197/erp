<UserControl x:Class="Erp.Desktop.Views.CodeExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Code Explorer" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#64748B"
                       Text="{Binding WorkspaceRootPath, StringFormat=Workspace: {0}}" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Height="30"
                     VerticalAlignment="Center"
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Column="1"
                       Margin="10,0,10,0"
                       VerticalAlignment="Center"
                       Foreground="#64748B"
                       Text="{Binding FilteredCount, StringFormat=Files: {0:N0}}" />

            <Button Grid.Column="2"
                    Width="90"
                    Height="30"
                    Content="Refresh"
                    Command="{Binding RefreshCommand}" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="6">
                <ListBox ItemsSource="{Binding FilteredFiles}"
                         SelectedItem="{Binding SelectedFile}"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="8,6">
                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding RelativePath}"
                                           Foreground="#64748B"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Column="2"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Padding="10"
                            BorderBrush="#E2E8F0"
                            BorderThickness="0,0,0,1"
                            Background="#F8FAFC">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Text="{Binding SelectedFilePath, TargetNullValue=파일을 선택하세요.}" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="#64748B"
                                       FontSize="12"
                                       Text="{Binding SelectedFileMeta}" />
                        </StackPanel>
                    </Border>

                    <TextBox Grid.Row="1"
                             Text="{Binding FileContent}"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="13"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             Padding="10" />
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3"
                   Margin="0,12,0,0"
                   Foreground="#B00020"
                   Text="{Binding StatusMessage}" />

        <Border Grid.RowSpan="4"
                Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                IsHitTestVisible="{Binding IsBusy}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="220" Height="10" />
                <TextBlock Text="Loading..." Margin="0,10,0,0" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
