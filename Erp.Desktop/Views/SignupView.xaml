<UserControl x:Class="Erp.Desktop.Views.SignupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Erp.Desktop.Controls">
    <Grid Background="#F5F7FA">
        <Border Width="400"
                Padding="24"
                Background="White"
                BorderBrush="#D7DCE3"
                BorderThickness="1"
                CornerRadius="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="회원가입" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="가입 후 관리자 승인 완료 시 로그인할 수 있습니다."
                           Margin="0,6,0,20"
                           Foreground="#667085"
                           TextWrapping="Wrap" />

                <TextBlock Text="아이디" Margin="0,0,0,4" />
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="비밀번호" Margin="0,12,0,4" />
                <PasswordBox x:Name="PasswordBox"
                             PasswordChanged="PasswordBox_OnPasswordChanged" />

                <TextBlock Text="이메일(선택)" Margin="0,12,0,4" />
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                <controls:ValidationSummary Margin="0,12,0,0"
                                            Errors="{Binding ValidationErrors}"
                                            HasErrors="{Binding HasValidationErrors}" />

                <controls:MessageBar Margin="0,10,0,0"
                                     Message="{Binding UserMessage.Text}"
                                     Kind="{Binding UserMessage.Kind}"
                                     IsOpen="{Binding HasUserMessage}" />

                <Button Content="가입 신청"
                        Command="{Binding RegisterCommand}"
                        Margin="0,16,0,0"
                        Height="36" />

                <Button Content="로그인 화면으로 돌아가기"
                        Command="{Binding BackToLoginCommand}"
                        Margin="0,10,0,0"
                        Height="32">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRegistrationSucceeded}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <controls:BusyOverlay IsBusy="{Binding IsBusy}" Message="{Binding BusyMessage}" />
    </Grid>
</UserControl>
