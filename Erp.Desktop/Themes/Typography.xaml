<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <FontFamily x:Key="FontFamily.App">Segoe UI</FontFamily>

    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamily.App}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="Text.WindowTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamily.App}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextInverse}" />
    </Style>

    <Style x:Key="Text.GroupTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamily.App}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.GroupTitle}" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="Text.Badge" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamily.App}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextInverse}" />
    </Style>

    <Style x:Key="Text.TopBarInfo" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamily.App}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextInverse}" />
    </Style>
</ResourceDictionary>
