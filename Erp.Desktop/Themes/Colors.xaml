<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="Color.WindowBackground">#FFF2F4F8</Color>
    <Color x:Key="Color.SurfacePrimary">#FFFFFFFF</Color>
    <Color x:Key="Color.SurfaceAlt">#FFF8FAFC</Color>
    <Color x:Key="Color.TopBarBackground">#FF13233A</Color>
    <Color x:Key="Color.SidebarBackground">#FF0B1730</Color>
    <Color x:Key="Color.BorderDefault">#FFD0D7E2</Color>
    <Color x:Key="Color.TextPrimary">#FF0F172A</Color>
    <Color x:Key="Color.TextSecondary">#FF475467</Color>
    <Color x:Key="Color.TextInverse">#FFE2E8F0</Color>
    <Color x:Key="Color.GroupTitle">#FF93A4C3</Color>
    <Color x:Key="Color.Accent">#FF1D4ED8</Color>
    <Color x:Key="Color.AccentSoft">#FFDBEAFE</Color>
    <Color x:Key="Color.AccentStrong">#FFBBD6FF</Color>
    <Color x:Key="Color.Success">#FF067647</Color>
    <Color x:Key="Color.Warning">#FFB54708</Color>
    <Color x:Key="Color.Danger">#FFB42318</Color>

    <SolidColorBrush x:Key="Brush.WindowBackground" Color="{StaticResource Color.WindowBackground}" />
    <SolidColorBrush x:Key="Brush.SurfacePrimary" Color="{StaticResource Color.SurfacePrimary}" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="{StaticResource Color.SurfaceAlt}" />
    <SolidColorBrush x:Key="Brush.TopBarBackground" Color="{StaticResource Color.TopBarBackground}" />
    <SolidColorBrush x:Key="Brush.SidebarBackground" Color="{StaticResource Color.SidebarBackground}" />
    <SolidColorBrush x:Key="Brush.BorderDefault" Color="{StaticResource Color.BorderDefault}" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.TextInverse" Color="{StaticResource Color.TextInverse}" />
    <SolidColorBrush x:Key="Brush.GroupTitle" Color="{StaticResource Color.GroupTitle}" />
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.AccentSoft" Color="{StaticResource Color.AccentSoft}" />
    <SolidColorBrush x:Key="Brush.AccentStrong" Color="{StaticResource Color.AccentStrong}" />
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}" />
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}" />
</ResourceDictionary>
