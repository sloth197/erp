<UserControl x:Class="Erp.Desktop.Controls.StatusBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border x:Name="BadgeBorder"
            Padding="10,4"
            CornerRadius="12"
            BorderThickness="1">
        <TextBlock x:Name="BadgeText"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Text="{Binding DisplayText, ElementName=Root}" />
    </Border>
</UserControl>
