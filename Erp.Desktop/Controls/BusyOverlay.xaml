<UserControl x:Class="Erp.Desktop.Controls.BusyOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             IsHitTestVisible="{Binding IsBusy, ElementName=Root}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Border Background="#70FFFFFF"
            Visibility="{Binding IsBusy, ElementName=Root, Converter={StaticResource BoolToVisibility}}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <ProgressBar Width="240" Height="10" IsIndeterminate="True" />
            <TextBlock Margin="0,10,0,0"
                       Foreground="#1F2937"
                       Text="{Binding Message, ElementName=Root, TargetNullValue=Loading...}" />
        </StackPanel>
    </Border>
</UserControl>
